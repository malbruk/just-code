{
  "name": "just-code",
  "displayName": "Just Code",
  "description": "Just code, nothing else. A community VS Code chat extension on the Claude Agent SDK",
  "version": "1.1.0",
  "publisher": "MaBrukDev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/malbruk/just-code.git"
  },
  "bugs": {
    "url": "https://github.com/malbruk/just-code/issues"
  },
  "homepage": "https://github.com/malbruk/just-code#readme",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Machine Learning"
  ],
  "keywords": [
    "claude",
    "anthropic",
    "ai",
    "agent",
    "coding assistant",
    "chat"
  ],
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1f1f1f",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "Just Code runs an agent that edits files and executes shell commands in this workspace, and loads MCP servers declared in the workspace's .mcp.json — which start processes defined by the repository. Only enable it in workspaces you trust."
    }
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "just-code",
          "title": "Just Code",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "views": {
      "just-code": [
        {
          "type": "webview",
          "id": "just-code.chat",
          "name": "Just Code",
          "icon": "media/activity-icon.svg",
          "contextualTitle": "Just Code"
        }
      ]
    },
    "commands": [
      {
        "command": "just-code.openChat",
        "title": "Open Just Code",
        "category": "Just Code",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "just-code.newChat",
        "title": "New Chat",
        "category": "Just Code",
        "icon": "$(add)"
      },
      {
        "command": "just-code.newChatInEditor",
        "title": "New Chat in Editor",
        "category": "Just Code",
        "icon": "$(split-horizontal)"
      },
      {
        "command": "just-code.stop",
        "title": "Stop",
        "category": "Just Code",
        "icon": "$(stop-circle)"
      },
      {
        "command": "just-code.history",
        "title": "Show Chat History",
        "category": "Just Code",
        "icon": "$(history)"
      },
      {
        "command": "just-code.addSelectionToChat",
        "title": "Add Selection to Just Code",
        "category": "Just Code",
        "icon": "$(add)"
      },
      {
        "command": "just-code.addFileToChat",
        "title": "Add File to Just Code",
        "category": "Just Code"
      },
      {
        "command": "just-code.explainSelection",
        "title": "Explain Selection",
        "category": "Just Code"
      },
      {
        "command": "just-code.fixSelection",
        "title": "Fix Selection with Claude",
        "category": "Just Code"
      },
      {
        "command": "just-code.acceptAllEdits",
        "title": "Accept All Edits",
        "category": "Just Code",
        "icon": "$(check-all)"
      },
      {
        "command": "just-code.rejectAllEdits",
        "title": "Reject All Edits",
        "category": "Just Code",
        "icon": "$(discard)"
      },
      {
        "command": "just-code.acceptEdit",
        "title": "Accept Edit",
        "category": "Just Code",
        "icon": "$(check)"
      },
      {
        "command": "just-code.rejectEdit",
        "title": "Reject Edit",
        "category": "Just Code",
        "icon": "$(discard)"
      },
      {
        "command": "just-code.selectModel",
        "title": "Select Model",
        "category": "Just Code"
      },
      {
        "command": "just-code.setPermissionMode",
        "title": "Set Permission Mode",
        "category": "Just Code"
      },
      {
        "command": "just-code.signIn",
        "title": "Sign In / Set API Key",
        "category": "Just Code"
      },
      {
        "command": "just-code.signOut",
        "title": "Sign Out",
        "category": "Just Code"
      },
      {
        "command": "just-code.rewind",
        "title": "Rewind to Checkpoint",
        "category": "Just Code",
        "icon": "$(discard)"
      },
      {
        "command": "just-code.focusInput",
        "title": "Focus Chat Input",
        "category": "Just Code"
      },
      {
        "command": "just-code.moveView",
        "title": "Move Chat to Side Drawer…",
        "category": "Just Code",
        "icon": "$(layout-sidebar-right)"
      }
    ],
    "keybindings": [
      {
        "command": "just-code.openChat",
        "key": "ctrl+escape",
        "mac": "cmd+escape"
      },
      {
        "command": "just-code.addSelectionToChat",
        "key": "ctrl+alt+k",
        "mac": "cmd+alt+k",
        "when": "editorHasSelection"
      },
      {
        "command": "just-code.acceptAllEdits",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "just-code.hasPendingEdits"
      },
      {
        "command": "just-code.newChat",
        "key": "ctrl+alt+n",
        "mac": "cmd+alt+n",
        "when": "focusedView == just-code.chat"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "just-code.newChatInEditor",
          "when": "view == just-code.chat",
          "group": "navigation@1"
        },
        {
          "command": "just-code.moveView",
          "when": "view == just-code.chat",
          "group": "1_layout@1"
        }
      ],
      "editor/context": [
        {
          "command": "just-code.addSelectionToChat",
          "when": "editorHasSelection",
          "group": "just-code@1"
        },
        {
          "command": "just-code.explainSelection",
          "when": "editorHasSelection",
          "group": "just-code@2"
        },
        {
          "command": "just-code.fixSelection",
          "when": "editorHasSelection",
          "group": "just-code@3"
        }
      ],
      "explorer/context": [
        {
          "command": "just-code.addFileToChat",
          "group": "just-code@1"
        }
      ],
      "commandPalette": [
        {
          "command": "just-code.acceptEdit",
          "when": "false"
        },
        {
          "command": "just-code.rejectEdit",
          "when": "false"
        },
        {
          "command": "just-code.focusInput",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "Just Code",
      "properties": {
        "just-code.model": {
          "type": "string",
          "default": "default",
          "enum": [
            "default",
            "claude-opus-4-8",
            "claude-sonnet-5",
            "claude-haiku-4-5-20251001"
          ],
          "enumDescriptions": [
            "Use the account default model",
            "Claude Opus 4.8 — most capable",
            "Claude Sonnet 5 — balanced",
            "Claude Haiku 4.5 — fastest"
          ],
          "description": "The Claude model to use for the agent."
        },
        "just-code.permissionMode": {
          "type": "string",
          "default": "default",
          "enum": [
            "default",
            "acceptEdits",
            "plan",
            "bypassPermissions"
          ],
          "enumDescriptions": [
            "Ask for permission before each tool use",
            "Automatically accept file edits",
            "Plan mode — read-only, propose a plan before acting",
            "Bypass all permission prompts (use with caution)"
          ],
          "description": "Default permission mode for tool usage."
        },
        "just-code.authMethod": {
          "type": "string",
          "default": "subscription",
          "enum": [
            "subscription",
            "apiKey"
          ],
          "enumDescriptions": [
            "Use your Claude Pro/Max subscription via claude.ai login (OAuth)",
            "Use an Anthropic API key (Console usage billing)"
          ],
          "description": "How to authenticate with Anthropic. 'subscription' signs in with your claude.ai account; 'apiKey' uses a Console API key.",
          "scope": "application"
        },
        "just-code.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Your Anthropic API key (used only when `#just-code.authMethod#` is `apiKey`). Prefer the **Sign In** command, which stores the key in secret storage. Leave empty to use the `ANTHROPIC_API_KEY` environment variable.",
          "scope": "application"
        },
        "just-code.claudeExecutablePath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Full path to the `claude` executable. Leave empty to auto-detect (checks `PATH`, npm global installs, and the native installer). Must point at the real binary, not an npm launcher script — though a launcher script will be followed to its target. Supports `~` and `${env:VAR}`.",
          "scope": "application"
        },
        "just-code.maxTurns": {
          "type": "number",
          "default": 100,
          "description": "Maximum number of agent turns per request."
        },
        "just-code.thinkingBudget": {
          "type": "number",
          "default": 0,
          "description": "Max thinking tokens (0 = model default). Higher enables extended thinking."
        },
        "just-code.extendedThinking": {
          "type": "boolean",
          "default": true,
          "description": "Enable extended thinking. Toggled live from the composer's Actions menu."
        },
        "just-code.effort": {
          "type": "string",
          "default": "default",
          "enum": [
            "default",
            "low",
            "medium",
            "high",
            "xhigh",
            "max"
          ],
          "enumDescriptions": [
            "Use the model default (high)",
            "Minimal thinking, fastest responses",
            "Moderate thinking",
            "Deep reasoning",
            "Deeper than high (supported models only)",
            "Maximum effort (supported models only)"
          ],
          "markdownDescription": "Reasoning effort level (SDK `effort`). Changing it applies to the next chat/turn."
        },
        "just-code.autoModelFallback": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Switch to a fallback model when the primary is flagged or fails (SDK `fallbackModel`)."
        },
        "just-code.additionalDirectories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional directories the agent is allowed to access, beyond the workspace."
        },
        "just-code.loadProjectSettings": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Load filesystem settings — user (`~/.claude`), project (`.claude`), and local (`.claude/settings.local.json`). This is what enables `CLAUDE.md` files and **MCP servers**. Turning it off runs the agent in isolation with no MCP."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "vsix": "vsce package -o just-code.vsix",
    "publish:check": "node scripts/preflight.js",
    "publish:marketplace": "npm run publish:check && vsce publish --azure-credential",
    "publish:marketplace:pat": "npm run publish:check && vsce publish"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.202"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.93.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^26.1.0",
    "@types/vscode": "~1.90.0",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  }
}
