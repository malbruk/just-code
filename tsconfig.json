{
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "@just-code/core": ["./packages/core/src/index.ts"],
      "@just-code/core/*": ["./packages/core/src/*"]
    },
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "src/**/*.ts",
    "webview-ui/**/*.ts",
    "packages/core/src/**/*.ts",
    "packages/intellij-plugin/sidecar/src/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "media"]
}
